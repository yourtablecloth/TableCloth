<Page x:Class="TableCloth.Pages.QuickStartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:res="clr-namespace:TableCloth.Resources;assembly=TableCloth.Core"
      xmlns:vm="clr-namespace:TableCloth.ViewModels"
      xmlns:tablecloth="clr-namespace:TableCloth;assembly=TableCloth.Core"
      mc:Ignorable="d"
      d:DesignHeight="600" d:DesignWidth="800"
      Title="{x:Static res:UIStringResources.QuickStart_Title}"
      d:DataContext="{d:DesignInstance Type=vm:QuickStartPageViewModelForDesigner, IsDesignTimeCreatable=True}">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding QuickStartPageLoadedCommand}">
                <i:InvokeCommandAction.CommandParameter>
                    <Binding Path="DataContext" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type Page}}" />
                </i:InvokeCommandAction.CommandParameter>
            </i:InvokeCommandAction>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Info Banner -->
        <Border Grid.Row="0"
                Background="{DynamicResource InfoBannerBackground}"
                BorderBrush="{DynamicResource InfoBannerBorder}"
                BorderThickness="0 0 0 1" Padding="8 6">
            <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" Foreground="{DynamicResource InfoBannerForeground}">
                <Run Text="ⓘ" FontWeight="Bold" Foreground="{DynamicResource InfoBannerLinkForeground}" /><Run Text=" " /><Run Text="{x:Static res:UIStringResources.Sponsor_BannerMessage}" /><Run Text=" " /><Hyperlink Click="SponsorBanner_MouseLeftButtonUp" Foreground="{DynamicResource InfoBannerLinkForeground}" FontWeight="SemiBold"><Run Text="{x:Static res:UIStringResources.Sponsor_BannerDetailLink}" /></Hyperlink>
            </TextBlock>
        </Border>

        <!-- Centered hero with title + instruction + launch button + NPKI 공유 상태 링크 -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" MaxWidth="520" Margin="24">
            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" FontSize="28" FontWeight="Bold" Text="{x:Static res:UIStringResources.QuickStart_Title}" />
            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0 12 0 24" TextWrapping="Wrap"
                       Foreground="{DynamicResource ControlSecondaryForeground}"
                       Text="{x:Static res:UIStringResources.QuickStart_Instruction}" />
            <Button HorizontalAlignment="Center" MinWidth="220" Padding="28 12" FontSize="16" FontWeight="Bold"
                    Content="{x:Static res:UIStringResources.QuickStart_LaunchButton}"
                    Command="{Binding LaunchSandboxCommand}" />
            <!-- NPKI 공유 상태: 현재 상태를 문장으로 보여주고, 클릭하면 옵션 창이 열려 토글 가능 -->
            <TextBlock HorizontalAlignment="Center" TextAlignment="Center" Margin="0 16 0 0" TextWrapping="Wrap">
                <Hyperlink Command="{Binding OpenOptionsCommand}">
                    <Run Text="{Binding NpkiStatusText, Mode=OneWay}" />
                </Hyperlink>
            </TextBlock>
        </StackPanel>

        <!-- Footer: 모두 하이퍼링크로 통일하여 시각적 강조를 시작 버튼으로 집중시킨다 -->
        <Grid Grid.Row="2" Margin="16 8 16 12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <TextBlock Margin="0 0 12 0" VerticalAlignment="Center">
                    <Hyperlink Command="{Binding AboutThisAppCommand}">
                        <Run Text="{x:Static res:UIStringResources.Button_AboutButton}" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock VerticalAlignment="Center" Visibility="{Binding Source={x:Static tablecloth:Helpers.IsDevelopmentBuild}, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Hyperlink Command="{Binding ShowDebugInfoCommand}">
                        <Run Text="{x:Static res:UIStringResources.Button_DebugButton}" />
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
            <TextBlock Grid.Column="2" VerticalAlignment="Center">
                <Hyperlink Command="{Binding OpenOptionsCommand}">
                    <Run Text="{x:Static res:UIStringResources.QuickStart_OptionsButton}" />
                </Hyperlink>
            </TextBlock>
        </Grid>
    </Grid>
</Page>
