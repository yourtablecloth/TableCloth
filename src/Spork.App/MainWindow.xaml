<Window x:Class="Spork.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Spork"
        xmlns:tablecloth="clr-namespace:TableCloth;assembly=TableCloth.Core"
        xmlns:vm="clr-namespace:Spork.ViewModels"
        xmlns:res="clr-namespace:TableCloth.Resources;assembly=TableCloth.Core"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainWindowViewModelForDesigner, IsDesignTimeCreatable=True}"
        Style="{DynamicResource MainWindowStyle}"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Title="{x:Static res:UIStringResources.Spork_AppTitle}" Width="720" Height="560" MinWidth="520" MinHeight="420"
        TextOptions.TextFormattingMode="Display" TextOptions.TextRenderingMode="ClearType">
    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Loaded">
            <i:InvokeCommandAction Command="{Binding MainWindowLoadedCommand}">
                <i:InvokeCommandAction.CommandParameter>
                    <Binding Path="DataContext" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}" />
                </i:InvokeCommandAction.CommandParameter>
            </i:InvokeCommandAction>
        </i:EventTrigger>
    </i:Interaction.Triggers>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition d:Height="45" Height="{Binding ShowDryRunNotification, Converter={StaticResource BooleanToGridRowHeightConverter}, ConverterParameter='45'}" />
            <RowDefinition Height="*"/>
            <RowDefinition Height="55"/>
        </Grid.RowDefinitions>

        <!-- Info Banner -->
        <Border Grid.Row="0"
                Background="{DynamicResource InfoBannerBackground}"
                BorderBrush="{DynamicResource InfoBannerBorder}"
                BorderThickness="0 0 0 1" Padding="8 6">
            <TextBlock VerticalAlignment="Center" TextWrapping="Wrap" FontSize="11" Foreground="{DynamicResource InfoBannerForeground}">
                <Run Text="ⓘ" FontWeight="Bold" Foreground="{DynamicResource InfoBannerLinkForeground}" /><Run Text=" " /><Run Text="{x:Static res:UIStringResources.Sponsor_BannerShortMessage}" /><Run Text=" " /><Hyperlink Click="SponsorBanner_MouseLeftButtonUp" Foreground="{DynamicResource InfoBannerLinkForeground}" FontWeight="SemiBold" FontSize="11"><Run Text="{x:Static res:UIStringResources.Sponsor_BannerDetailLink}" /></Hyperlink>
            </TextBlock>
        </Border>

        <Label Grid.Row="1" Background="{Binding Source={x:Static SystemColors.ActiveBorderBrush}}" Foreground="{Binding Source={x:Static SystemColors.ActiveCaptionTextBrush}}">
            <Label.Content>
                <TextBlock VerticalAlignment="Center" FontWeight="Bold" Margin="5 0 0 0" Text="{x:Static res:UIStringResources.Spork_DryRunInstructionMessage}" TextWrapping="Wrap" />
            </Label.Content>
        </Label>

        <!-- Catalog Mode -->
        <Grid Grid.Row="2" Margin="10" Visibility="{Binding ShowCatalogView, Converter={StaticResource booleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Margin="0 0 0 6" TextWrapping="Wrap" Text="{x:Static res:UIStringResources.SporkCatalog_Instruction}" />

            <TabControl Grid.Row="1">
                <!-- 웹 사이트 카탈로그 -->
                <TabItem Header="{x:Static res:UIStringResources.SporkCatalog_Tab_Sites}">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0 0 0 6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Padding="6 4" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                        <Style.Resources>
                                            <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                                <VisualBrush.Visual>
                                                    <Label Content="{x:Static res:UIStringResources.SearchFilter_Watermark}" Foreground="LightGray" />
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="{x:Static sys:String.Empty}">
                                                <Setter Property="Background" Value="{StaticResource CueBannerBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <CheckBox Grid.Column="1" Margin="8 0 0 0" VerticalAlignment="Center"
                                      Content="{x:Static res:UIStringResources.MainWindow_Favorites}"
                                      IsChecked="{Binding ShowFavoritesOnly}" />
                        </Grid>

                        <ListView Grid.Row="1" x:Name="CatalogList"
                      ItemsSource="{Binding CatalogServices}" d:ItemsSource="{Binding CatalogServicesForDesigner}"
                      SelectedItem="{Binding SelectedCatalogService}"
                      SelectionMode="Single"
                      VirtualizingPanel.IsContainerVirtualizable="True"
                      VirtualizingPanel.IsVirtualizing="True"
                      VirtualizingPanel.IsVirtualizingWhenGrouping="True"
                      HorizontalContentAlignment="Stretch">
                <ListView.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding CatalogItemActivateCommand}" />
                </ListView.InputBindings>
                <ListView.Template>
                    <ControlTemplate>
                        <ScrollViewer CanContentScroll="False" HorizontalScrollBarVisibility="Disabled">
                            <ItemsPresenter />
                        </ScrollViewer>
                    </ControlTemplate>
                </ListView.Template>
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel IsItemsHost="True" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="Margin" Value="4" />
                        <Setter Property="Padding" Value="4" />
                        <Setter Property="MinWidth" Value="96" />
                        <Setter Property="MinHeight" Value="110" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- ListView의 selection 처리 때문에 자식 InputBindings(LeftClick)는
                             선택 변화 시 일부 클릭이 무시될 수 있어, 코드비하인드의
                             CatalogItem_MouseLeftButtonUp이 직접 처리한다. 즐겨찾기 별을 누르면
                             ToggleButton이 e.Handled=true로 표시하므로 이 핸들러는 발화되지 않는다.
                             Cursor=Hand로 클릭 가능 항목임을 시각적으로 알린다(하이퍼링크 동선과 동등). -->
                        <Grid Width="96" MinHeight="100" Background="Transparent"
                              Cursor="Hand"
                              MouseLeftButtonUp="CatalogItem_MouseLeftButtonUp">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="48" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Image Grid.Row="0" Source="{Binding Id, Mode=OneWay, Converter={StaticResource ServiceLogoConverter}}"
                                   RenderOptions.BitmapScalingMode="Fant" HorizontalAlignment="Center" VerticalAlignment="Center" Stretch="Uniform" />
                            <!-- Favorite star toggle -->
                            <ToggleButton Grid.Row="0" Width="14" Height="14" IsChecked="{Binding IsFavorite}"
                                          HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"
                                          Cursor="Hand"
                                          Command="{Binding RelativeSource={RelativeSource AncestorType=Window, Mode=FindAncestor}, Path=DataContext.ToggleFavoriteCommand}"
                                          CommandParameter="{Binding}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Grid>
                                            <Grid.Resources>
                                                <Geometry x:Key="StarPathData">M 26.285 2.486 l 5.407 10.956 c 0.376 0.762 1.103 1.29 1.944 1.412 l 12.091 1.757 c 2.118 0.308 2.963 2.91 1.431 4.403 l -8.749 8.528 c -0.608 0.593 -0.886 1.448 -0.742 2.285 l 2.065 12.042 c 0.362 2.109 -1.852 3.717 -3.746 2.722 l -10.814 -5.685 c -0.752 -0.395 -1.651 -0.395 -2.403 0 l -10.814 5.685 c -1.894 0.996 -4.108 -0.613 -3.746 -2.722 l 2.065 -12.042 c 0.144 -0.837 -0.134 -1.692 -0.742 -2.285 l -8.749 -8.528 c -1.532 -1.494 -0.687 -4.096 1.431 -4.403 l 12.091 -1.757 c 0.841 -0.122 1.568 -0.65 1.944 -1.412 l 5.407 -10.956 C 22.602 0.567 25.338 0.567 26.285 2.486 z</Geometry>
                                            </Grid.Resources>
                                            <Border Background="Transparent">
                                                <Path Data="{StaticResource StarPathData}" Fill="Transparent" Stroke="Black" StrokeThickness="5" StrokeLineJoin="Round" Stretch="Uniform" />
                                            </Border>
                                            <Border Background="Transparent">
                                                <Path x:Name="StarFill" Data="{StaticResource StarPathData}" Fill="LightGray" Stretch="Uniform" />
                                            </Border>
                                        </Grid>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="StarFill" Property="Fill" Value="#FFD401" />
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="False">
                                                <Setter TargetName="StarFill" Property="Fill" Value="LightGray" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <StackPanel Grid.Row="1" Orientation="Vertical" HorizontalAlignment="Stretch" Margin="0 4 0 0">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" TextAlignment="Center" MaxHeight="34" />
                                <TextBlock Text="{Binding CategoryDisplayName}" FontSize="10" Foreground="Gray" Margin="0 2 0 0" TextAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="2 6 0 2">
                                    <TextBlock Text="{Binding Name}" FontWeight="Bold" />
                                    <TextBlock Text="{Binding ItemCount, StringFormat={x:Static res:UIStringResources.CatalogPage_ItemCountLabel}}" FontWeight="Bold" Margin="6 0 0 0" />
                                </StackPanel>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                        </ListView>
                    </Grid>
                </TabItem>

                <!-- 공동인증서 카탈로그 -->
                <TabItem Header="{x:Static res:UIStringResources.SporkCatalog_Tab_Certificates}">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Margin="0 0 0 6" TextWrapping="Wrap"
                                   Foreground="{DynamicResource ControlSecondaryForeground}"
                                   Text="{x:Static res:UIStringResources.SporkCatalog_Certificates_Description}" />
                        <!-- 비어 있을 때 안내 메시지 (Count==0일 때만 노출) -->
                        <TextBlock Grid.Row="1" Margin="0 12 0 0" TextAlignment="Center"
                                   Foreground="{DynamicResource ControlSecondaryForeground}"
                                   Text="{x:Static res:UIStringResources.SporkCatalog_Certificates_Empty}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CatalogCertificates.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CatalogCertificates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <!-- 각 항목은 Hyperlink로 노출, 클릭 시 Windows 표준 인증서 속성 창 표시.
                                             만료된 인증서는 TextBlock 전체에 취소선 + 회색 처리. Run에 자동 상속. -->
                                        <TextBlock Margin="6 4" TextWrapping="Wrap" ToolTip="{Binding Availability}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasExpired}" Value="True">
                                                            <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            <Setter Property="Foreground" Value="Gray" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                            <!-- 인증서 항목은 클릭 가능하지만 시각적으로는 일반 텍스트처럼 보이게 한다.
                                                 기본 상태에서는 밑줄/링크 색을 제거하고 부모 TextBlock의 Foreground를
                                                 그대로 상속받아 만료(회색+취소선) 스타일이 자연스럽게 적용되게 한다.
                                                 마우스 호버 시에만 밑줄을 그려 클릭 가능함을 알린다. -->
                                            <Hyperlink Command="{Binding RelativeSource={RelativeSource AncestorType=Window, Mode=FindAncestor}, Path=DataContext.ShowCertificateDetailsCommand}"
                                                       CommandParameter="{Binding}">
                                                <Hyperlink.Style>
                                                    <Style TargetType="Hyperlink">
                                                        <Setter Property="TextDecorations" Value="{x:Null}" />
                                                        <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TextBlock}}" />
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="TextDecorations" Value="Underline" />
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Hyperlink.Style>
                                                <Run FontWeight="SemiBold" Text="{Binding CommonName, Mode=OneWay}" />
                                                <Run Text=" · " />
                                                <Run Text="{Binding Organization, Mode=OneWay}" />
                                                <LineBreak />
                                                <Run FontSize="10" Text="{Binding NotBefore, StringFormat=yyyy-MM-dd, Mode=OneWay}" />
                                                <Run FontSize="10" Text=" ~ " />
                                                <Run FontSize="10" Text="{Binding NotAfter, StringFormat=yyyy-MM-dd, Mode=OneWay}" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>

                <!-- 보조 프로그램 카탈로그 -->
                <TabItem Header="{x:Static res:UIStringResources.SporkCatalog_Tab_Companions}">
                    <Grid Margin="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Margin="0 0 0 6" TextWrapping="Wrap"
                                   Foreground="{DynamicResource ControlSecondaryForeground}"
                                   Text="{x:Static res:UIStringResources.SporkCatalog_Companions_Description}" />
                        <!-- 보조 프로그램은 저작권/EULA 동의 흐름 때문에 자동 설치하지 않고
                             공식 다운로드 페이지로 안내한다. 각 항목은 하이퍼링크 형태로 노출. -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding CatalogCompanions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Margin="6 4">
                                            <Hyperlink Command="{Binding RelativeSource={RelativeSource AncestorType=Window, Mode=FindAncestor}, Path=DataContext.OpenCompanionUrlCommand}"
                                                       CommandParameter="{Binding}"
                                                       ToolTip="{Binding Url}">
                                                <Run Text="{Binding DisplayName}" />
                                            </Hyperlink>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Steps Mode -->
        <Grid Grid.Row="2" Margin="10" Visibility="{Binding ShowStepsView, Converter={StaticResource booleanToVisibilityConverter}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Margin="0 0 0 6" TextWrapping="WrapWithOverflow" Text="{x:Static res:UIStringResources.Spork_AppInstructionMessage}" />
            <ListBox Grid.Row="1" x:Name="listView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Hidden" ItemsSource="{Binding InstallSteps}" d:ItemsSource="{Binding InstallStepsForDesigner}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Vertical" Width="{Binding ActualWidth, ElementName=listView, Converter={StaticResource widthConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="Flag" Text="{Binding Path='InstallFlags'}" Foreground="{Binding Path='Installed', Converter={StaticResource stateToBrushConverter}}" Margin="0 0 5 0" FontWeight="Bold" />
                                <TextBlock Text="{Binding Path='TargetSiteName'}" Margin="0 0 5 0" FontWeight="Bold" />
                                <TextBlock Text="{Binding Path='PackageName'}" Margin="0 0 5 0" />
                                <TextBlock Text="{Binding Path='StatusMessage'}" Margin="0 0 5 0" Foreground="{Binding Path='Installed', Converter={StaticResource stateToBrushConverter}}" />
                                <Button Command="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type Window}}, Path='ViewModel.ShowErrorMessageCommand'}"
                                        CommandParameter="{Binding Path='ErrorMessage'}"
                                        Content="{x:Static res:UIStringResources.Spork_ShowDetailError}"
                                        Visibility="{Binding Path='ShowErrorMessageLink', Converter={StaticResource booleanToVisibilityConverter}}"
                                        Margin="0 0 5 0" BorderThickness="0" Background="Transparent" Cursor="Hand" />
                            </StackPanel>
                            <ProgressBar Height="10" Margin="5 5 5 5" Value="{Binding ProgressRate}" Visibility="{Binding Path='ShowProgress', Converter={StaticResource booleanToVisibilityConverter}}" />
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <WrapPanel HorizontalAlignment="Left" VerticalAlignment="Center" Grid.Column="0">
                <TextBlock Margin="10 0 0 0" VerticalAlignment="Center">
                    <Hyperlink Command="{Binding AboutThisAppCommand}">
                        <Run Text="{x:Static res:UIStringResources.Button_AboutButton}" />
                    </Hyperlink>
                </TextBlock>
                <!-- 사이트 제보: 카탈로그 모드에서만 노출 (사용자가 사이트 목록을 보고 있을 때 유효) -->
                <TextBlock Margin="12 0 0 0" VerticalAlignment="Center"
                           Visibility="{Binding ShowCatalogView, Converter={StaticResource booleanToVisibilityConverter}}">
                    <Hyperlink Command="{Binding ReportSiteCommand}">
                        <Run Text="{x:Static res:UIStringResources.Button_ReportSiteButton}" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock Margin="12 0 0 0" VerticalAlignment="Center"
                           Visibility="{Binding Source={x:Static tablecloth:Helpers.IsDevelopmentBuild}, Converter={StaticResource booleanToVisibilityConverter}}">
                    <Hyperlink Command="{Binding ShowDebugInfoCommand}">
                        <Run Text="{x:Static res:UIStringResources.Button_DebugButton}" />
                    </Hyperlink>
                </TextBlock>
            </WrapPanel>
            <WrapPanel HorizontalAlignment="Right" VerticalAlignment="Center" Grid.Column="1">
                <!-- 카탈로그 모드는 사이트 클릭으로 바로 실행되므로 별도 "시작" 버튼 없음. -->
                <!-- Steps mode: 설치 (명령줄 select 인자 진입 시에만 사용. 카탈로그 진입은 모달로 처리). -->
                <Button Margin="0 0 10 0" Padding="5" Content="{x:Static res:UIStringResources.Button_InstallButton}"
                        Command="{Binding MainWindowInstallPackagesCommand}"
                        Visibility="{Binding ShowStepsView, Converter={StaticResource booleanToVisibilityConverter}}" />
            </WrapPanel>
        </Grid>
    </Grid>
</Window>
